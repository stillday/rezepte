# MongoDB
MONGO_URI=mongodb://localhost:27017/rezepte

# Google OAuth (https://console.cloud.google.com)
# Authorized redirect URI: https://rezepte.gilneas.at/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth.js secret: openssl rand -base64 32
AUTH_SECRET=

# Gemini (für OCR + URL-Import + Instagram/TikTok-Caption)
GEMINI_API_KEY=
# Optional: Gemini-Modell überschreiben (Default gemini-2.5-flash)
GEMINI_MODEL=

# Instagram-Import: angemeldete Session via instaloader (Wegwerf-Account empfohlen!).
# TikTok geht ohne; Instagram drosselt Server-IPs und verlangt Login.
# Erste Session am besten lokal bootstrappen: IG_*-Vars setzen, dann
#   /opt/ytdlp/bin/python scripts/ig_fetch.py --login
# und die erzeugte Session-Datei nach IG_SESSION_DIR auf den Server kopieren.
IG_USERNAME=
IG_PASSWORD=
IG_TOTP_SECRET=          # nur bei 2FA (TOTP-Secret des Authenticators)
IG_SESSION_DIR=/app/cookies

# Optional (Fallback): yt-dlp-Cookies-Datei (Netscape-Format) für Instagram.
YTDLP_COOKIES_FILE=/app/cookies/instagram.txt

# Bring! Zugangsdaten (gleiche wie MCP)
BRING_EMAIL=
BRING_PASSWORD=
BRING_LIST_UUID=   # Optional: bevorzugte Listen-UUID (sonst erste Liste)
